{
    "name": "njord",
    "runArgs": [
        "--privileged",
        "--device=/dev/ttyUSB0",
        "--device=/dev/video0"
    ],
    "build": {
        "dockerfile": "../Containerfile",
        "context": ".."
    },
    "workspaceFolder": "/workspace",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
    "postCreateCommand": "bash -c 'source /opt/ros/jazzy/setup.bash && pip install --break-system-packages --no-cache-dir \"numpy<2\" onnxruntime opencv-python-headless rplidar-roboticia && colcon build --symlink-install'",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.pylance",
                "ms-iot.vscode-ros"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/bin/python3",
                "python.analysis.extraPaths": [
                    "/opt/ros/jazzy/lib/python3.12/site-packages",
                    "/workspace/src/sensors",
                    "/workspace/src/perception",
                    "/workspace/src/control",
                    "/workspace/src/mission",
                    "/workspace/src/vision"
                ],
                "terminal.integrated.defaultProfile.linux": "bash"
            }
        }
    }
}
