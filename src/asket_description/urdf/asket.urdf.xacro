<?xml version="1.0"?>
<robot name="asket" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Root frame — centre of the boat -->
  <link name="base_link"/>

  <!-- LIDAR — mounted at base_link origin -->
  <link name="lidar"/>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Camera — mounted 10 cm forward of the LIDAR -->
  <link name="camera"/>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera"/>
    <origin xyz="0.1 0 0" rpy="0 0 0"/>
  </joint>

</robot>
